# Browser-safe TxLINE settings. In local development, Vite serves /txline.
# In production, set VITE_TXLINE_PROXY_URL to the Railway proxy endpoint.
VITE_TXLINE_ENABLE_LIVE=true
VITE_TXLINE_PROXY_URL=
VITE_TXLINE_COMPETITION_ID=
VITE_TXLINE_FIXTURE_START_EPOCH_DAY=20639
VITE_TXLINE_FIXTURE_LOOKBACK_DAYS=14

# Server-only TxLINE credentials. Never rename these with a VITE_ prefix.
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_GUEST_JWT=<your-txline-guest-jwt>
TXLINE_API_TOKEN=<your-txline-api-token>

# Browser-safe TxPools program settings.
VITE_TXPOOLS_CLUSTER=devnet
VITE_TXPOOLS_PROGRAM_ID=txpWnpDSkz98Xgm451KBpezot1YL4FM8LnnUA4Tyfh1
VITE_TXPOOLS_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
VITE_TXPOOLS_BOOTSTRAP_ADMIN=<your-browser-admin-wallet>

# Public browser RPC defaults. Production reads should use the Railway proxy;
# transaction submission remains on the public Solana Devnet endpoint.
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_SOLANA_RPC_PROXY_URL=
VITE_SOLANA_TRANSACTION_RPC_URL=https://api.devnet.solana.com
VITE_SOLANA_USE_DEV_PROXY=true

# Railway/indexer settings. PORT is injected by Railway automatically.
TXPOOLS_INDEXER_RPC_URL=<your-helius-devnet-rpc>
TXPOOLS_INDEXER_PORT=8787
TXPOOLS_INDEXER_POLL_MS=15000
TXPOOLS_INDEXER_DB_PATH=./txpools.sqlite
TXPOOLS_PROGRAM_ID=txpWnpDSkz98Xgm451KBpezot1YL4FM8LnnUA4Tyfh1
TXPOOLS_ALLOWED_ORIGINS=http://localhost:5173
TXPOOLS_PROXY_REQUESTS_PER_MINUTE=180

# Local URLs. Set all three to the generated Railway domain in Vercel.
VITE_TXPOOLS_INDEXER_URL=http://localhost:8787
# Example production value: https://your-service.up.railway.app/txline
# VITE_TXLINE_PROXY_URL=https://your-service.up.railway.app/txline
# VITE_SOLANA_RPC_PROXY_URL=https://your-service.up.railway.app/solana-rpc
